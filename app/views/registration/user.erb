<%= bootstrap_form_for(@form, url: wizard_path, :method => :put, layout: :horizontal, label_col: 'col-sm-3', control_col: 'col-sm-8') do |f| %>

  <%= f.text_field :first_name, autofocus: true %>

  <%= f.text_field :last_name, autofocus: true %>

  <%= f.email_field :email, autofocus: true, autocomplete: "email" %>

  <%= f.password_field :password, autocomplete: "new-password", help: t("devise.registrations.minimum_password_length_help_text", :length => @minimum_password_length) %>

  <div class="actions">
    <%= wizard_next_button %>
  </div>
<% end %>