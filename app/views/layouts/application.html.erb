<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

  <title>CoderAlert</title>
  <%= favicon_link_tag asset_path('') %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>

<!--    <p class="float-right">-->
<%# if user_signed_in? %>
<!--        Logged in as <strong><%#= current_user.email %></strong>.-->
<!--        <%#= link_to 'Edit profile', edit_user_registration_path, :class => 'navbar-link' %> |-->
<%#= link_to "Logout", destroy_user_session_path, method: :delete, :class => 'navbar-link'  %>
<%# else %>
<!--        <%#= link_to "Sign up", new_user_registration_path, :class => 'navbar-link'  %> |-->
<%#= link_to "Login", new_user_session_path, :class => 'navbar-link'  %>
<%# end %>
<!--    </p>-->


<body class="app is-collapsed <%= controller_name %> <%= action_name %>">

<!-- @App Content -->
<!-- =================================================== -->
<div>

  <div id="modal-window" class="modal fade" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content"></div>
    </div>
  </div>

  <!-- #Left Sidebar ==================== -->
  <div class="sidebar">
    <div class="sidebar-inner">
      <!-- ### $Sidebar Header ### -->
      <div class="sidebar-logo">
        <a href="#">
          <%= image_tag('logo.png', width: 200) %>
        </a>
      </div>

      <!-- ### $Sidebar Menu ### -->
      <ul class="sidebar-menu scrollable pos-r">
        <li class="nav-item mT-30 actived">
          <%#= link_to root_path do %>
<!--                    <span class="icon-holder">-->
<!--                      <i class="c-blue-500 ti-home"></i>-->
<!--                    </span>-->
<!--            <span class="title"><%#= t(:my_custom_lists, :scope => :sidebar) %></span>-->
          <%# end %>
        </li>

        <li class="nav-item">
          <%= link_to '' do %>
                <span class="icon-holder">
                  <i class="c-pink-300 ti-ticket"></i>
                </span>
            <span class="title"><%= t(:fee_calculator, :scope => :sidebar) %></span>
          <% end %>
        </li>

        <li class="nav-item">
          <%= link_to '' do %>
                <span class="icon-holder">
                  <i class="c-grey-900 ti-user"></i>
                </span>
            <span class="title"><%= t(:team, :scope => :sidebar) %></span>
          <% end %>
        </li>

        <li class="nav-item">
          <%= link_to '' do %>
                <span class="icon-holder">
                  <i class="c-green-500 ti-calendar"></i>
                </span>
            <span class="title"><%= t(:schedule, :scope => :sidebar) %></span>
          <% end %>
        </li>

        <li class="nav-item">
          <%= link_to '' do %>
                <span class="icon-holder">
                  <i class="c-purple-500 ti-book"></i>
                </span>
            <span class="title"><%= t(:knowledge_base, :scope => :sidebar) %></span>
          <% end %>
        </li>

        <li class="nav-item mt-3">
          <%= link_to '' do %>
                <span class="icon-holder">
                  <i class="c-red-500 ti-comment font-weight-bold"></i>
                </span>
            <span class="title"><%= t(:contact_us, :scope => :sidebar) %></span>
          <% end %>
        </li>
      </ul>
    </div>
  </div>

  <!-- #Main ============================ -->
  <div class="page-container">
    <!-- ### $Topbar ### -->
    <div>
      <div class="header-container">
        <span class="title"><%= t(:welcome, :name => 'Dr Static Singh', :scope => :header) %></span>

        <% if user_signed_in? %>
          <%= link_to destroy_user_session_path, class: 'd-b td-n c-grey-700', method: :delete do %>
            <i class="ti-power-off mR-10"></i>
            <span><%= t(:logout, :scope => :header) %></span>
          <% end %>
        <% else %>
          <%= link_to('Login', new_user_session_path) %>
        <% end %>
      </div>
    </div>

    <!-- ### $App Screen Content ### -->
    <main class='main-content bgc-grey-200'>
      <div id='mainContent'>
        <div class="row gap-20 masonry pos-r">
          <div class="masonry-item col-12">
            <div class="bgc-white p-20 bd">
              <% if notice %>
                <p class="alert alert-success"><%= notice %></p>
              <% end %>
              <% if alert %>
                <p class="alert alert-danger"><%= alert %></p>
              <% end %>
              <%= yield %>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- ### $App Screen Footer ### -->
    <footer class="bdT ta-c p-30 lh-0 fsz-sm c-grey-600">
      <span><%= t(:copyright, :scope => :footer) %></span>
    </footer>
  </div>
</div>
</body>
</html>
