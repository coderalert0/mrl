<div class="row">
  <div class="col-lg-12 col-md-6 col-sm-6">
    <div class="card">
      <div class="card-body ">
          <h3><%= @speciality.name %> (<%= @matching_programs.count %> Matches)</h3>

ERAS Fees based on programs bookmarked: <%= number_to_currency @fee %>

<table class="table">
  <thead>
    <tr>
      <th scope="col">Match Score™</th>
      <th scope="col">Program Name</th>
      <th scope="col">Location</th>
      <th scope="col">ACGME Program Code</th>
      <th scope="col">Bookmark</th>
    </tr>
  </thead>
  <tbody>

  <% @matching_programs.each do |program| %>
    <tr>
      <td>
        <%= program.send(current_user.img_type) %>
      </td>
      <td><%= link_to program.name, speciality_program_path(@speciality, program) %></td>
      <td><%= program.address.split[-3..-2].join(' ') %></td>
      <td><%= program.acgme_program_code %></td>
      <td>
        <span class="icon-holder">
          <%= link_to speciality_program_bookmark_url(@speciality, program), method: :post do %>
            <% if program.bookmarked?(current_user) %>
              <%= bootstrap_icon "bookmark-check-fill", fill: "green" %>
            <% else %>
              <%= bootstrap_icon "bookmark", fill: "gray" %>
            <% end %>
          <% end %>
        </span>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>
      </div>
    </div>
  </div>
</div>